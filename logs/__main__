<script>
(function () {
  const MONTO_MINIMO = 150000;

  function obtenerTotal() {
    const el = document.getElementById("importeTotalPedido");
    if (!el) return 0;
    return parseInt(el.innerText.replace(/\D/g, "")) || 0;
  }

  function crearBarra() {
    const totalEl = document.getElementById("importeTotalPedido");
    if (!totalEl) return;

    if (document.getElementById("minimo-compra-box")) return;

    const box = document.createElement("div");
    box.id = "minimo-compra-box";
    box.innerHTML = `
      <div id="minimo-compra-texto"></div>
      <div id="minimo-compra-barra">
        <div id="minimo-compra-progreso"></div>
      </div>
    `;

    totalEl.parentNode.insertBefore(box, totalEl);
  }

  function actualizarBarra() {
    const texto = document.getElementById("minimo-compra-texto");
    const progreso = document.getElementById("minimo-compra-progreso");
    if (!texto || !progreso) return;

    const total = obtenerTotal();

    if (total >= MONTO_MINIMO) {
      texto.innerHTML = "🎉 ¡Ya alcanzaste el mínimo de compra!";
      progreso.style.width = "100%";
      progreso.style.background = "#1bb04a";
    } else {
      const faltante = MONTO_MINIMO - total;
      const porcentaje = Math.min((total / MONTO_MINIMO) * 100, 100);

      texto.innerHTML =
        `Te faltan <strong>$${faltante.toLocaleString("es-AR")}</strong> para alcanzar el mínimo de compra`;

      progreso.style.width = porcentaje + "%";
      progreso.style.background = "#3483fa";
    }
  }

  // chequeo liviano y estable
  setInterval(function () {
    crearBarra();
    actualizarBarra();
  }, 500);
})();
</script>
	
	
