			<script>
			$(document).on("click", ".js-cart-quantity-btn", function (e) {
  e.preventDefault();
  var url =
    "\/carrito\/actualizar\/_id_pedido_\/_id_producto_\/_cantidad_\/1";
  var idProducto = 0;
  var idPedido = 0;

  var btnAction = $(this).data("btn");
  var quantity = parseFloat(
    $(this).closest(".ajax-cart-item").find(".cart-quantity-input").val()
  );

  var input = $("#" + $(this).attr("id").replace("cantidadMax_", "cantidad_"));
  if (btnAction == "restar") {
    $(
      "#" + $(this).attr("id").replace("cantidadMin_", "disponibles_")
    ).removeAttr("style");
    input = $("#" + $(this).attr("id").replace("cantidadMin_", "cantidad_"));
    quantity = quantity - 1;
    if (quantity <= 0) {
      quantity = 1;
    }
    idProducto = $(this).attr("id").replace("cantidadMin_", "");
  }
  if (btnAction == "sumar") {

    $("#" + $(this).attr("id").replace("cantidadMax_", "disponibles_")
    ).removeAttr("style");
    input = $("#" + $(this).attr("id").replace("cantidadMax_", "cantidad_"));
    
    max = input.attr("max");
    if (quantity + 1 > parseInt(max)) {
      $("#" + $(this).attr("id").replace("cantidadMax_", "disponibles_")).css({
        color: "red",
      });
      if (parseInt(max) > -1) {
        return;
      }
      
    }

    idProducto = $(this).attr("id").replace("cantidadMax_", "");
    quantity = quantity + 1;
  }
  var importeTotalProducto = $("#importeTotalProducto" + "_" + idProducto);

  idPedido = $("#idPedido").val();
  url = url.replace("_id_pedido_", idPedido);
  url = url.replace("_id_producto_", idProducto);
  url = url.replace("_cantidad_", quantity);
  loading = $(this).closest(".ajax-cart-item").find(".cart-quantity-loading");
  btn = $(this).closest(".ajax-cart-item").find(".cart-quantity-btn");
  //Actualizo el stock
  $.ajax({
    url: url,
    type: "GET",
    dataType: "JSON",
    beforeSend: function () {
      input.hide();
      loading.show();
      btn.attr("style", "pointer-events: none; opacity:.1;");
    },
    success: function (data) {
      
      var container = "";
      if (data["respuesta"] == "OK") {
        input.val(data["cantidad"]);
        importeTotalProducto.html(
