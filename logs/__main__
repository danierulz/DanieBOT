					<script>(function ($) {
  function moveInicioCarritoTop() {
    var $nav = $('.navMobile');
    var $ul = $('#componente_botonera_mobile');

    if (!$nav.length || !$ul.length) return;

    // Evitar duplicar si ya se ejecutó
    if ($ul.data('inicart_done')) return;

    // Tomo los links del footer
    var $aInicio  = $nav.find('.navFooter a[href="/"]').first();
    var $aCarrito = $nav.find('.navFooter a[href="/carrito"]').first();

    // Armo los LI nuevos (estilo categorías)
    function makeLi($a, label) {
      if (!$a.length) return null;
      return $('<li class="nav-top-link"></li>').append(
        $('<a></a>')
          .attr('href', $a.attr('href'))
          .text(label)
      );
    }

    var $liInicio  = makeLi($aInicio, 'Inicio');
    var $liCarrito = makeLi($aCarrito, 'Carrito de compras');

    // Insertar ARRIBA de OFERTAS (o al comienzo del UL)
    if ($liCarrito) $ul.prepend($liCarrito);
    if ($liInicio)  $ul.prepend($liInicio);

    // Ocultar footer completo
    $nav.find('.navFooter').hide();

    $ul.data('inicart_done', true);
  }

  $(document).ready(moveInicioCarritoTop);

  // Por si el menú se renderiza después / dinámico
  var obs = new MutationObserver(moveInicioCarritoTop);
  obs.observe(document.body, { childList: true, subtree: true });

  $(document).ajaxComplete(moveInicioCarritoTop);
})(jQuery);
